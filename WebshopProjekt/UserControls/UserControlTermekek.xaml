<UserControl x:Class="WebshopProjekt.UserControls.UserControlTermekek"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WebshopProjekt.UserControls"
             mc:Ignorable="d" 
             Width="1100"
             Height="700">
    <StackPanel Margin="0">
        <DataGrid
        x:Name="datagridTermekek"
        Width="1100"
        Height="400"
        AutoGenerateColumns="False"
        CanUserAddRows="False"
        CanUserDeleteRows="False"
        IsReadOnly="True"
        SelectionChanged="datagridTermekek_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Binding="{Binding Id}" Header="ID" />
                <DataGridTextColumn Binding="{Binding Name}" Header="Név" />
                <DataGridTextColumn Binding="{Binding Price, StringFormat={}{0:N0} Ft, ConverterCulture=hu-HU}" Header="Ár" />
                <DataGridTextColumn Binding="{Binding Category}" Header="Kategória" />
                <DataGridTextColumn Binding="{Binding Brand}" Header="Márka" />
            </DataGrid.Columns>
        </DataGrid>
        <WrapPanel Margin="10" VerticalAlignment="Bottom">
            <StackPanel Width="300">
                <TextBlock Text="Név:" />
                <TextBox x:Name="NevTxtBx" />
                <TextBlock Text="Ár:" />
                <TextBox x:Name="ArTxtBx" />
                <TextBlock Text="Kategória:" />
                <TextBox x:Name="KategoriaTxtBx" />
                <TextBlock Text="Márka:" />
                <TextBox x:Name="MarkaTxtBx" />
            </StackPanel>
            <StackPanel>
                <Button
                x:Name="mentesBtn"
                Width="200"
                Margin="20,10,0,0"
                Background="DarkSlateBlue"
                Click="mentesBtn_Click"
                Content="Mentés"
                Foreground="White"/>
                <Button
                x:Name="torlesBtn"
                Width="200"
                Margin="20,10,0,0"
                Background="Red"
                Click="torlesBtn_Click"
                Content="Törlés"
                Foreground="White" />
                <Button
                x:Name="modBtn"
                Width="200"
                Margin="20,10,0,0"
                Background="LightGoldenrodYellow"
                Click="modBtn_Click"
                Content="Módosítás" />

            </StackPanel>
        </WrapPanel>
    </StackPanel>
</UserControl>
